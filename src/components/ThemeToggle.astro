---
// 다크/라이트 모드 토글 버튼
---

<button
	id="theme-toggle"
	class="theme-toggle"
	type="button"
	aria-label="테마 전환"
	title="테마 전환"
>
	<svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
	</svg>
	<svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
		<circle cx="12" cy="12" r="5" />
		<line x1="12" y1="1" x2="12" y2="3" />
		<line x1="12" y1="21" x2="12" y2="23" />
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
		<line x1="1" y1="12" x2="3" y2="12" />
		<line x1="21" y1="12" x2="23" y2="12" />
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
	</svg>
</button>

<style>
	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		padding: 0;
		border: none;
		border-radius: 6px;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		transition: color 0.2s ease, background-color 0.2s ease;
	}

	.theme-toggle:hover {
		color: var(--accent);
		background-color: var(--panel);
	}

	/* Light mode: show moon, hide sun */
	:global(:root) .icon-sun {
		display: none;
	}

	:global(:root) .icon-moon {
		display: block;
	}

	/* Dark mode: show sun, hide moon */
	:global(:root[data-theme='dark']) .icon-sun {
		display: block;
	}

	:global(:root[data-theme='dark']) .icon-moon {
		display: none;
	}

	@media (max-width: 899px) {
		.theme-toggle {
			width: 36px;
			height: 36px;
		}
	}
</style>

<script>
	function initThemeToggle() {
		const btn = document.getElementById('theme-toggle');
		if (!btn) return;

		btn.addEventListener('click', () => {
			const root = document.documentElement;
			const current = root.getAttribute('data-theme');
			const next = current === 'dark' ? 'light' : 'dark';
			root.setAttribute('data-theme', next);
			localStorage.setItem('theme', next);
		});
	}

	initThemeToggle();
	document.addEventListener('astro:after-swap', initThemeToggle);
</script>
