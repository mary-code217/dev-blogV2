---
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	activeNav?: string;
}

const { activeNav } = Astro.props;

const nav = [
	{ id: 'home', label: 'Home', href: '/' },
	{ id: 'blog', label: 'Blog', href: '/blog/' },
];
---

<aside class="sidebar">
	<a class="sidebar__title" href="/">{SITE_TITLE}</a>

	<nav>
		<ul class="nav">
			{nav.map((item) => {
				const isActive = activeNav === item.id;
				return (
					<li>
						<a href={item.href} aria-current={isActive ? 'page' : undefined}>
							<span>{item.label}</span>
							<span class="dot" aria-hidden="true"></span>
						</a>
					</li>
				);
			})}
		</ul>
	</nav>

	<div class="sidebar-actions">
		<ThemeToggle />
	</div>
</aside>

<style>
	.sidebar {
		padding: 55px 24px;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 24px;
		position: sticky;
		top: 0;
		height: 100vh;
	}

	.sidebar__title {
		font-size: 28px;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		letter-spacing: 0.5px;
		transition: transform 0.2s ease;
		transform-origin: right center;
	}

	.sidebar__title:hover {
		transform: scale(1.05);
		text-decoration: none;
	}

	.nav {
		list-style: none;
		margin: 12px 0 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 6px;
	}

	.nav a {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 10px;
		color: var(--muted);
		text-decoration: none;
		font-size: 16px;
		padding: 2px 0;
		transition: transform 0.2s ease;
		transform-origin: right center;
	}

	.nav a:hover {
		transform: scale(1.05);
	}

	.nav a[aria-current='page'] {
		color: var(--text);
		text-decoration: underline;
		text-decoration-thickness: 1.5px;
		text-underline-offset: 5px;
	}

	.dot {
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background-color: var(--muted);
		opacity: 0.55;
		flex-shrink: 0;
	}

	.sidebar-actions {
		margin-top: auto;
		display: flex;
		align-items: center;
		gap: 8px;
	}

	/* Mobile: sidebar -> horizontal header */
	@media (max-width: 899px) {
		.sidebar {
			position: static;
			height: auto;
			padding: 16px var(--pad-x);
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			align-content: flex-start;
			gap: 12px;
		}

		.sidebar__title {
			order: 1;
			flex: 1 1 auto;
			font-size: 24px;
		}

		nav {
			order: 4;
			width: 100%;
		}

		.nav {
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: center;
			gap: 8px 12px;
			margin: 0;
		}

		.dot {
			display: none;
		}

		.sidebar-actions {
			order: 2;
			margin-top: 0;
			margin-left: auto;
		}
	}
</style>
