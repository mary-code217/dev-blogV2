---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';
import { SITE_TITLE } from '../consts';

interface Props {
	post: CollectionEntry<'blog'> | CollectionEntry<'wiki'>;
	prevPost?: CollectionEntry<'blog'> | CollectionEntry<'wiki'>;
	nextPost?: CollectionEntry<'blog'> | CollectionEntry<'wiki'>;
	headings: { depth: number; slug: string; text: string }[];
	basePath?: string;
}

const { post, prevPost, nextPost, headings, basePath = 'blog' } = Astro.props;
const { title, description, date, category, tags } = post.data;

const formattedDate = date.toLocaleDateString('ko-KR', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={`${title} - ${SITE_TITLE}`} description={description} activeNav="blog">
	<div class="post-layout">
		<article class="post-content">
			<!-- 글 헤더 -->
			<header class="post-header">
				<div class="post-meta">
					<span class="post-category">{category}</span>
					<time datetime={date.toISOString()}>{formattedDate}</time>
				</div>
				<h1 class="post-title">{title}</h1>
				{tags.length > 0 && (
					<div class="post-tags">
						{tags.map((tag) => (
							<span class="post-tag">{tag}</span>
						))}
					</div>
				)}
			</header>

			<!-- 모바일 TOC -->
			{tocHeadings.length > 0 && (
				<details class="toc-mobile">
					<summary>목차</summary>
					<nav>
						<ul>
							{tocHeadings.map((h) => (
								<li class={h.depth === 3 ? 'toc-indent' : ''}>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ul>
					</nav>
				</details>
			)}

			<!-- 글 본문 -->
			<div class="prose">
				<slot />
			</div>
			<CodeBlock />

			<!-- 이전/다음 글 -->
			<nav class="post-nav">
				{prevPost ? (
					<a href={`${import.meta.env.BASE_URL}${basePath}/${prevPost.id}/`} class="post-nav__link post-nav__prev">
						<span class="post-nav__label">&larr; 이전 글</span>
						<span class="post-nav__title">{prevPost.data.title}</span>
					</a>
				) : <div />}
				{nextPost ? (
					<a href={`${import.meta.env.BASE_URL}${basePath}/${nextPost.id}/`} class="post-nav__link post-nav__next">
						<span class="post-nav__label">다음 글 &rarr;</span>
						<span class="post-nav__title">{nextPost.data.title}</span>
					</a>
				) : <div />}
			</nav>
		</article>

		<!-- 데스크톱 TOC -->
		{tocHeadings.length > 0 && (
			<aside class="toc-desktop" id="toc-desktop">
				<nav>
					<p class="toc-title">목차</p>
					<ul>
						{tocHeadings.map((h) => (
							<li class={h.depth === 3 ? 'toc-indent' : ''}>
								<a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
							</li>
						))}
					</ul>
				</nav>
			</aside>
		)}
	</div>
</BaseLayout>

<style>
	.post-layout {
		display: flex;
		gap: var(--space-xl);
		position: relative;
	}

	.post-content {
		flex: 1;
		min-width: 0;
	}

	/* 글 헤더 */
	.post-header {
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-lg);
		border-bottom: 1px solid var(--border);
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: 0.875rem;
		color: var(--muted);
		margin-bottom: var(--space-sm);
	}

	.post-category {
		color: var(--accent);
		font-weight: 600;
	}

	.post-title {
		font-size: 2rem;
		font-weight: 700;
		line-height: 1.3;
		margin: 0 0 var(--space-md) 0;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
	}

	.post-tag {
		padding: 2px 8px;
		background-color: var(--panel);
		color: var(--muted);
		border-radius: 4px;
		font-size: 0.8rem;
	}

	/* 본문 */
	.prose {
		line-height: 1.75;
		overflow-x: hidden;
	}

	.prose :global(h2) {
		margin-top: 2em;
		margin-bottom: 0.5em;
		padding-bottom: 0.3em;
		border-bottom: 1px solid var(--border);
	}

	.prose :global(h3) {
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}

	.prose :global(p) {
		margin-bottom: 1.25em;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin-bottom: 1.25em;
		padding-left: 1.5em;
	}

	.prose :global(li) {
		margin-bottom: 0.25em;
	}

	.prose :global(pre) {
		margin: 1.5em 0;
	}

	.prose :global(blockquote) {
		margin: 1.5em 0;
	}

	.prose :global(img) {
		border-radius: 8px;
		margin: 1.5em 0;
	}

	/* 이전/다음 글 네비 */
	.post-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
		margin-top: var(--space-xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--border);
	}

	.post-nav__link {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-md);
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		color: var(--text);
		transition: background-color 0.2s ease;
	}

	.post-nav__link:hover {
		background-color: var(--panel);
		text-decoration: none;
	}

	.post-nav__next {
		text-align: right;
	}

	.post-nav__label {
		font-size: 0.8rem;
		color: var(--muted);
	}

	.post-nav__title {
		font-size: 0.9rem;
		font-weight: 600;
	}

	/* 모바일 TOC */
	.toc-mobile {
		margin-bottom: var(--space-lg);
		border: 1px solid var(--border);
		border-radius: 6px;
		padding: var(--space-md);
	}

	.toc-mobile summary {
		cursor: pointer;
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--text);
	}

	.toc-mobile ul {
		list-style: none;
		margin: var(--space-sm) 0 0 0;
		padding: 0;
	}

	.toc-mobile li {
		margin: 4px 0;
	}

	.toc-mobile a {
		font-size: 0.85rem;
		color: var(--muted);
		text-decoration: none;
	}

	.toc-mobile a:hover {
		color: var(--accent);
	}

	.toc-mobile .toc-indent {
		padding-left: 1em;
	}

	/* 데스크톱 TOC */
	.toc-desktop {
		display: none;
	}

	@media (min-width: 1200px) {
		.toc-desktop {
			display: block;
			position: sticky;
			top: 56px;
			width: 200px;
			flex-shrink: 0;
			max-height: calc(100vh - 112px);
			overflow-y: auto;
			align-self: flex-start;
		}

		.toc-mobile {
			display: none;
		}
	}

	.toc-title {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--text);
		margin: 0 0 var(--space-sm) 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.toc-desktop ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.toc-desktop li {
		margin: 2px 0;
	}

	.toc-desktop a {
		display: block;
		font-size: 0.8rem;
		color: var(--faint);
		text-decoration: none;
		padding: 2px 0 2px 8px;
		border-left: 2px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.toc-desktop a:hover {
		color: var(--accent);
	}

	.toc-desktop a.active {
		color: var(--accent);
		border-left-color: var(--accent);
	}

	.toc-desktop .toc-indent a {
		padding-left: 1.5em;
	}

	@media (max-width: 899px) {
		.post-title {
			font-size: 1.75rem;
		}

		.prose :global(h2) {
			margin-top: 1.5em;
		}

		.prose :global(pre) {
			margin: 1em 0;
		}

		.prose :global(blockquote) {
			margin: 1em 0;
		}
	}

	@media (max-width: 640px) {
		.post-title {
			font-size: 1.5rem;
		}

		.post-nav {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	function initScrollSpy() {
		const tocLinks = document.querySelectorAll<HTMLAnchorElement>('#toc-desktop a[data-slug]');
		if (tocLinks.length === 0) return;

		const headingEls = Array.from(tocLinks).map((link) => {
			return document.getElementById(link.dataset.slug || '');
		}).filter(Boolean) as HTMLElement[];

		let ticking = false;

		function update() {
			const scrollY = window.scrollY + 100;
			let currentId = '';

			for (const el of headingEls) {
				if (el.offsetTop <= scrollY) {
					currentId = el.id;
				}
			}

			tocLinks.forEach((link) => {
				link.classList.toggle('active', link.dataset.slug === currentId);
			});
		}

		window.addEventListener('scroll', () => {
			if (!ticking) {
				ticking = true;
				requestAnimationFrame(() => {
					update();
					ticking = false;
				});
			}
		}, { passive: true });

		update();
	}

	initScrollSpy();
	document.addEventListener('astro:after-swap', initScrollSpy);
</script>
