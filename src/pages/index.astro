---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const wikiPosts = await getCollection('wiki', ({ data }) => !data.draft);

const posts = [
	...blogPosts.map((post) => ({ ...post, basePath: 'blog' })),
	...wikiPosts.map((post) => ({ ...post, basePath: 'wiki' })),
]
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);

---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} activeNav="home">
	<section class="home-posts">
			<h2 class="section-title">최신 글</h2>

			{posts.length > 0 ? (
				<div class="post-list">
					{posts.map((post) => (
						<PostCard
							title={post.data.title}
							description={post.data.description}
							date={post.data.date}
							category={post.data.category}
							slug={post.id}
							basePath={post.basePath}
							showType
						/>
					))}
				</div>
			) : (
				<p class="empty-state">아직 작성된 글이 없습니다.</p>
			)}

			<div class="view-all">
				<a href={`${import.meta.env.BASE_URL}blog/`} class="view-all__link">Blog 전체 보기 &rarr;</a>
				<a href={`${import.meta.env.BASE_URL}wiki/`} class="view-all__link">Wiki 전체 보기 &rarr;</a>
			</div>
		</section>
</BaseLayout>

<style>
	.section-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 var(--space-md) 0;
	}

	.post-list {
		display: flex;
		flex-direction: column;
	}

	.empty-state {
		color: var(--muted);
		padding: var(--space-xl) 0;
		text-align: center;
	}

	.view-all {
		margin-top: var(--space-lg);
		display: flex;
		justify-content: center;
		gap: var(--space-sm);
		flex-wrap: wrap;
	}

	.view-all__link {
		display: inline-flex;
		align-items: center;
		padding: 10px 24px;
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text);
		font-size: 0.875rem;
		text-decoration: none;
		min-height: var(--tap-min-h);
		transition: background-color 0.2s ease, color 0.2s ease;
	}

	.view-all__link:hover {
		background-color: var(--panel);
		text-decoration: none;
	}

</style>
