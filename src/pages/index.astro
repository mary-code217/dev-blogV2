---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 6);

const wikiPosts = (await getCollection('wiki', ({ data }) => !data.draft))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} activeNav="home">
	<section class="home-posts">
		<h2 class="section-title">최신 글</h2>

		{posts.length > 0 ? (
			<div class="post-list">
				{posts.map((post) => (
					<PostCard
						title={post.data.title}
						description={post.data.description}
						date={post.data.date}
						category={post.data.category}
						slug={post.id}
					/>
				))}
			</div>
		) : (
			<p class="empty-state">아직 작성된 글이 없습니다.</p>
		)}

		<div class="view-all">
			<a href={`${import.meta.env.BASE_URL}blog/`} class="view-all__link">전체 글 보기 &rarr;</a>
		</div>
	</section>

	{wikiPosts.length > 0 && (
		<section class="home-wiki">
			<h2 class="section-title section-title--wiki">Wiki</h2>

			<div class="wiki-list">
				{wikiPosts.map((post) => (
					<a href={`${import.meta.env.BASE_URL}wiki/${post.id}/`} class="wiki-item">
						<span class="wiki-item__category">{post.data.category}</span>
						<span class="wiki-item__title">{post.data.title}</span>
					</a>
				))}
			</div>

			<div class="view-all">
				<a href={`${import.meta.env.BASE_URL}wiki/`} class="view-all__link">전체 보기 &rarr;</a>
			</div>
		</section>
	)}
</BaseLayout>

<style>
	.section-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 var(--space-md) 0;
	}

	.post-list {
		display: flex;
		flex-direction: column;
	}

	.empty-state {
		color: var(--muted);
		padding: var(--space-xl) 0;
		text-align: center;
	}

	.view-all {
		margin-top: var(--space-lg);
		text-align: center;
	}

	.view-all__link {
		display: inline-flex;
		align-items: center;
		padding: 10px 24px;
		border: 1px solid var(--border);
		border-radius: 6px;
		color: var(--text);
		font-size: 0.875rem;
		text-decoration: none;
		min-height: var(--tap-min-h);
		transition: background-color 0.2s ease, color 0.2s ease;
	}

	.view-all__link:hover {
		background-color: var(--panel);
		text-decoration: none;
	}

	/* Wiki Section */
	.home-wiki {
		margin-top: var(--space-xl);
		padding-top: var(--space-lg);
		border-top: 1px solid var(--border);
	}

	.section-title--wiki {
		font-size: 1.1rem;
		color: var(--muted);
	}

	.wiki-list {
		display: flex;
		flex-direction: column;
	}

	.wiki-item {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		padding: 8px 14px;
		border-radius: 8px;
		text-decoration: none;
		color: var(--text);
		font-size: 0.9rem;
		transition: background-color 0.2s ease;
	}

	.wiki-item:hover {
		background-color: var(--code-header-bg);
		text-decoration: none;
	}

	.wiki-item__category {
		font-size: 0.75rem;
		color: var(--accent);
		font-weight: 600;
		flex-shrink: 0;
	}

	.wiki-item__title {
		color: var(--text);
	}
</style>
