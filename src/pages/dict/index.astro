---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { glossary } from '../../data/glossary';

const terms = [...glossary].sort((a, b) => a.term.localeCompare(b.term, 'ko'));
const categories = [...new Set(terms.map((t) => t.category))].sort();

// 독립적으로 흐르는 2개 세로 컬럼으로 분할 (한 카드를 열면 그 컬럼만 밀림)
const mid = Math.ceil(terms.length / 2);
const columns = [terms.slice(0, mid), terms.slice(mid)];
---

<BaseLayout title={`Dict - ${SITE_TITLE}`} description="개발 용어를 한눈에 정리한 사전" activeNav="dict">
	<section class="dict">
		<h1 class="page-title">Dict</h1>
		<p class="page-desc">개발하면서 마주친 용어들을 모아둔 공간</p>

		<!-- 용어 검색 -->
		<div class="search-wrap">
			<input
				type="search"
				id="dict-search"
				class="search-input"
				placeholder="용어 검색..."
				aria-label="용어 검색"
			/>
		</div>

		<!-- 카테고리 필터 -->
		<div class="filter-group" id="category-filter">
			<button class="filter-btn active" data-category="all">전체</button>
			{categories.map((cat) => (
				<button class="filter-btn" data-category={cat}>{cat}</button>
			))}
		</div>

		<!-- 카드 그리드 -->
		<div class="dict-grid" id="dict-grid">
			{columns.map((col, colIdx) => (
				<div class="dict-col">
					{col.map((t, i) => (
						<details
							class="dict-card"
							data-category={t.category}
							data-order={colIdx === 0 ? i : mid + i}
							data-search={`${t.term} ${t.description}`.toLowerCase()}
						>
							<summary class="dict-card__head">
								<h2 class="dict-card__term">{t.term}</h2>
								<span class="dict-card__right">
									<span class="dict-card__cat">{t.category}</span>
									<svg class="dict-card__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<polyline points="6 9 12 15 18 9" />
									</svg>
								</span>
							</summary>
							<p class="dict-card__desc">{t.description}</p>
						</details>
					))}
				</div>
			))}
		</div>

		<!-- 빈 상태 -->
		<p class="empty-state" id="empty-state" hidden>조건에 맞는 용어가 없습니다.</p>
	</section>
</BaseLayout>

<style>
	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 var(--space-xs) 0;
	}

	.page-desc {
		color: var(--muted);
		margin: 0 0 var(--space-lg) 0;
		font-size: 0.9rem;
	}

	.search-wrap {
		margin-bottom: var(--space-md);
	}

	.search-input {
		width: 100%;
		padding: 10px 16px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background-color: var(--bg);
		color: var(--text);
		font-size: 0.9rem;
		font-family: inherit;
		outline: none;
		transition: border-color 0.2s ease;
	}

	.search-input::placeholder {
		color: var(--faint);
	}

	.search-input:focus {
		border-color: var(--accent);
	}

	.filter-group {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-bottom: var(--space-lg);
	}

	.filter-btn {
		padding: 6px 16px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: transparent;
		color: var(--text);
		font-size: 0.875rem;
		cursor: pointer;
		min-height: var(--tap-min-h);
		font-family: inherit;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.filter-btn:hover {
		background-color: var(--panel);
	}

	.filter-btn.active {
		background-color: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}

	.dict-grid {
		display: flex;
		align-items: flex-start;
		gap: var(--space-md);
	}

	.dict-col {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
	}

	@media (max-width: 640px) {
		.dict-grid {
			flex-direction: column;
		}
	}

	.dict-card {
		border: 1px solid var(--border);
		border-radius: 10px;
		background-color: var(--bg);
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}

	.dict-card[hidden] {
		display: none;
	}

	.dict-card:hover {
		border-color: var(--accent);
	}

	.dict-card__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding: var(--space-md);
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.dict-card__head::-webkit-details-marker {
		display: none;
	}

	.dict-card__term {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.3;
	}

	.dict-card__right {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		flex-shrink: 0;
	}

	.dict-card__chevron {
		color: var(--faint);
		transition: transform 0.2s ease;
	}

	.dict-card[open] .dict-card__chevron {
		transform: rotate(180deg);
	}

	.dict-card__cat {
		flex-shrink: 0;
		font-size: 0.7rem;
		color: var(--muted);
		background-color: var(--panel);
		padding: 2px 8px;
		border-radius: 4px;
	}

	.dict-card__desc {
		font-size: 0.875rem;
		color: var(--muted);
		line-height: 1.6;
		margin: 0;
		padding: 0 var(--space-md) var(--space-md);
	}

	.empty-state {
		color: var(--muted);
		padding: var(--space-xl) 0;
		text-align: center;
	}
</style>

<script>
	function initDict() {
		let activeCategory = 'all';
		let query = '';

		const cards = Array.from(document.querySelectorAll<HTMLElement>('.dict-card'));
		const cols = Array.from(document.querySelectorAll<HTMLElement>('#dict-grid .dict-col'));
		const catBtns = document.querySelectorAll<HTMLButtonElement>('#category-filter .filter-btn');
		const input = document.getElementById('dict-search') as HTMLInputElement | null;
		const emptyState = document.getElementById('empty-state');

		function render() {
			const visible: HTMLElement[] = [];
			cards.forEach((card) => {
				const cat = card.dataset.category || '';
				const text = card.dataset.search || '';
				const catMatch = activeCategory === 'all' || cat === activeCategory;
				const queryMatch = !query || text.includes(query);
				const show = catMatch && queryMatch;
				card.hidden = !show;
				if (show) visible.push(card);
			});

			// 보이는 카드만 원래 정렬 순서대로 좌→우 두 컬럼에 재분배
			if (cols.length >= 2) {
				visible.sort(
					(a, b) => Number(a.dataset.order || 0) - Number(b.dataset.order || 0),
				);
				const half = Math.ceil(visible.length / 2);
				visible.forEach((card, i) => {
					cols[i < half ? 0 : 1].appendChild(card);
				});
			}

			if (emptyState) emptyState.hidden = visible.length > 0;
		}

		catBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				activeCategory = btn.dataset.category || 'all';
				catBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				render();
			});
		});

		input?.addEventListener('input', () => {
			query = input.value.trim().toLowerCase();
			render();
		});

		render();
	}

	initDict();
	document.addEventListener('astro:after-swap', initDict);
</script>
