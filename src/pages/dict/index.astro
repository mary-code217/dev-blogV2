---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { glossary } from '../../data/glossary';

const terms = [...glossary].sort((a, b) => a.term.localeCompare(b.term, 'ko'));
const categories = [...new Set(terms.map((t) => t.category))].sort();
---

<BaseLayout title={`Dict - ${SITE_TITLE}`} description="개발 용어를 한눈에 정리한 사전" activeNav="dict">
	<section class="dict">
		<h1 class="page-title">Dict</h1>
		<p class="page-desc">개발하면서 마주친 용어들을 모아둔 공간</p>

		<!-- 용어 검색 -->
		<div class="search-wrap">
			<input
				type="search"
				id="dict-search"
				class="search-input"
				placeholder="용어 검색..."
				aria-label="용어 검색"
			/>
		</div>

		<!-- 카테고리 필터 -->
		<div class="filter-group" id="category-filter">
			<button class="filter-btn active" data-category="all">전체</button>
			{categories.map((cat) => (
				<button class="filter-btn" data-category={cat}>{cat}</button>
			))}
		</div>

		<!-- 카드 그리드 -->
		<div class="dict-grid" id="dict-grid">
			{terms.map((t) => (
				<article
					class="dict-card"
					data-category={t.category}
					data-search={`${t.term} ${t.description}`.toLowerCase()}
				>
					<div class="dict-card__head">
						<h2 class="dict-card__term">{t.term}</h2>
						<span class="dict-card__cat">{t.category}</span>
					</div>
					<p class="dict-card__desc">{t.description}</p>
				</article>
			))}
		</div>

		<!-- 빈 상태 -->
		<p class="empty-state" id="empty-state" hidden>조건에 맞는 용어가 없습니다.</p>
	</section>
</BaseLayout>

<style>
	.page-title {
		font-size: 2rem;
		font-weight: 700;
		margin: 0 0 var(--space-xs) 0;
	}

	.page-desc {
		color: var(--muted);
		margin: 0 0 var(--space-lg) 0;
		font-size: 0.9rem;
	}

	.search-wrap {
		margin-bottom: var(--space-md);
	}

	.search-input {
		width: 100%;
		padding: 10px 16px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background-color: var(--bg);
		color: var(--text);
		font-size: 0.9rem;
		font-family: inherit;
		outline: none;
		transition: border-color 0.2s ease;
	}

	.search-input::placeholder {
		color: var(--faint);
	}

	.search-input:focus {
		border-color: var(--accent);
	}

	.filter-group {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		margin-bottom: var(--space-lg);
	}

	.filter-btn {
		padding: 6px 16px;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: transparent;
		color: var(--text);
		font-size: 0.875rem;
		cursor: pointer;
		min-height: var(--tap-min-h);
		font-family: inherit;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.filter-btn:hover {
		background-color: var(--panel);
	}

	.filter-btn.active {
		background-color: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}

	.dict-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: var(--space-md);
	}

	.dict-card {
		padding: var(--space-md);
		border: 1px solid var(--border);
		border-radius: 10px;
		background-color: var(--bg);
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}

	.dict-card[hidden] {
		display: none;
	}

	.dict-card:hover {
		border-color: var(--accent);
		background-color: var(--panel);
	}

	.dict-card__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-sm);
		margin-bottom: var(--space-xs);
	}

	.dict-card__term {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.3;
	}

	.dict-card__cat {
		flex-shrink: 0;
		font-size: 0.7rem;
		color: var(--muted);
		background-color: var(--panel);
		padding: 2px 8px;
		border-radius: 4px;
	}

	.dict-card:hover .dict-card__cat {
		background-color: var(--bg);
	}

	.dict-card__desc {
		font-size: 0.875rem;
		color: var(--muted);
		line-height: 1.6;
		margin: 0;
	}

	.empty-state {
		color: var(--muted);
		padding: var(--space-xl) 0;
		text-align: center;
	}
</style>

<script>
	function initDict() {
		let activeCategory = 'all';
		let query = '';

		const cards = Array.from(document.querySelectorAll<HTMLElement>('.dict-card'));
		const catBtns = document.querySelectorAll<HTMLButtonElement>('#category-filter .filter-btn');
		const input = document.getElementById('dict-search') as HTMLInputElement | null;
		const emptyState = document.getElementById('empty-state');

		function render() {
			let visible = 0;
			cards.forEach((card) => {
				const cat = card.dataset.category || '';
				const text = card.dataset.search || '';
				const catMatch = activeCategory === 'all' || cat === activeCategory;
				const queryMatch = !query || text.includes(query);
				const show = catMatch && queryMatch;
				card.hidden = !show;
				if (show) visible++;
			});
			if (emptyState) emptyState.hidden = visible > 0;
		}

		catBtns.forEach((btn) => {
			btn.addEventListener('click', () => {
				activeCategory = btn.dataset.category || 'all';
				catBtns.forEach((b) => b.classList.remove('active'));
				btn.classList.add('active');
				render();
			});
		});

		input?.addEventListener('input', () => {
			query = input.value.trim().toLowerCase();
			render();
		});

		render();
	}

	initDict();
	document.addEventListener('astro:after-swap', initDict);
</script>
